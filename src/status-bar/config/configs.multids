title: $:/plugins/linonetwo/status-bar/config/

showInSidebar: yes
autoHideEmpty: yes
position: sidebar
customStyles: no
orderByField: list-order

# Valor de estilo personalizado
customStyleValues/icon-size: 32px
customStyleValues/icon-gap: 0.5em
customStyleValues/background-opacity: 1
customStyleValues/background-blur: 0px
customStyleValues/border-radius: 4px
customStyleValues/animation: yes
