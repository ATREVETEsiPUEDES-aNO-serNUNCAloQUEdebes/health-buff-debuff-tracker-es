!! Personaliza la posicion de la barra de estado

<$radio tiddler=<<config-base>> field="position" value="top"> <<lingo Config/Position/Top>> </$radio>
<$radio tiddler=<<config-base>> field="position" value="sidebar"> <<lingo Config/Position/Sidebar>> </$radio>
<$radio tiddler=<<config-base>> field="position" value="both"> <<lingo Config/Position/Both>> </$radio>

<$reveal type="match" state=<<config-base>> index="customStyles" text="yes">
